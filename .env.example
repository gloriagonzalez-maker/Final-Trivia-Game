# copy this to .env and fill in your values when running locally
SHEET_ID=your_sheet_id_here                      # Google Sheet ID (required)

# Path to service account JSON (avoid committing this file)
# Alternatively you can embed the JSON directly into an env var
GOOGLE_APPLICATION_CREDENTIALS=credentials.json
#GOOGLE_APPLICATION_CREDENTIALS_JSON={"type":"service_account",...}

# Comma-separated list of allowed origins for CORS (leave blank to allow all)
# Example: https://example.com,http://localhost:3000
ALLOWED_ORIGINS=
